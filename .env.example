# Copy this file to .env and fill in your values
# Never commit .env

# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_API_KEY=your-google-ai-studio-api-key
GOOGLE_GENAI_USE_VERTEXAI=true

# ── Vertex AI ─────────────────────────────────────────────────────────────────
RAG_CORPUS_ID=projects/YOUR_PROJECT/locations/us-central1/ragCorpora/YOUR_CORPUS_ID
AGENT_ENGINE_ID=your-agent-engine-id

# ── Cloud Run service URLs (set after deploy) ─────────────────────────────────
MCP_URL=https://bi-tools-server-YOUR_HASH.us-central1.run.app/mcp
AUDIT_A2A_URL=https://audit-agent-service-YOUR_HASH.us-central1.run.app

# ── MCP Toolbox (local only) ──────────────────────────────────────────────────
TOOLBOX_URL=http://127.0.0.1:5000

# ── Langfuse observability (optional) ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── HITL store ────────────────────────────────────────────────────────────────
HITL_STORE=hitl_queue.json
