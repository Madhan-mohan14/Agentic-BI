    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ Build step done. Run /teach to get a learning recap of what was just built.'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
